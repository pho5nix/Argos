# Argos — environment configuration template.
# Copy this to .env and adjust values for your environment.

# ---------------------------------------------------------------------------
# Operating mode
# ---------------------------------------------------------------------------
# - "demo": runs against synthetic data, allows hosted-model fallback (off by
#           default), enables verbose logging. NEVER use with real customer data.
# - "production": strict. Requires self-hosted LLM backend, disables all fallbacks,
#                 enforces audit log signing, rejects missing governance policies.
ARGOS_MODE=demo

# ---------------------------------------------------------------------------
# Reasoning backend
# ---------------------------------------------------------------------------
# The demo uses Ollama. Production uses vLLM with XGrammar constrained decoding.
# See argos/reasoning.py for the backend interface.
ARGOS_REASONING_BACKEND=ollama
ARGOS_OLLAMA_URL=http://localhost:11434
ARGOS_OLLAMA_MODEL=qwen2.5:7b-instruct

# For production vLLM deployment (ignored in demo mode):
# ARGOS_VLLM_URL=http://vllm:8000
# ARGOS_VLLM_MODEL=Qwen/Qwen2.5-32B-Instruct

# ---------------------------------------------------------------------------
# PII pseudonymization (Presidio)
# ---------------------------------------------------------------------------
# Every free-text field from external sources passes through Presidio BEFORE
# reaching the LLM. See argos/privacy.py and docs/THREAT_MODEL.md#asi01-goal-hijack.
ARGOS_PRESIDIO_ANALYZER_URL=http://localhost:5002
ARGOS_PRESIDIO_ANONYMIZER_URL=http://localhost:5001

# ---------------------------------------------------------------------------
# Governance and audit
# ---------------------------------------------------------------------------
# The audit log is append-only and hash-chained. See argos/audit.py.
# In production, this should be on a WORM volume or signed storage.
ARGOS_AUDIT_LOG_PATH=./data/audit.log

# OPA Rego policies enforced by the governance layer.
ARGOS_POLICIES_PATH=./policies/argos.rego

# ---------------------------------------------------------------------------
# Case management connector
# ---------------------------------------------------------------------------
# Supported: "stdout" (demo), "thehive", "rest"
ARGOS_CASE_CONNECTOR=stdout

# For TheHive (ignored unless ARGOS_CASE_CONNECTOR=thehive):
# ARGOS_THEHIVE_URL=
# ARGOS_THEHIVE_API_KEY=

# ---------------------------------------------------------------------------
# Demo server
# ---------------------------------------------------------------------------
ARGOS_HTTP_HOST=0.0.0.0
ARGOS_HTTP_PORT=8080
